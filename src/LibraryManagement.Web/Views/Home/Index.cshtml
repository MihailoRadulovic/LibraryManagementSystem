@{
    ViewData["Title"] = "Početna";
}

<style>
    .hero-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 60px 40px;
        border-radius: 20px;
        color: white;
        text-align: center;
        margin-bottom: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }
    
    .hero-title {
        font-size: 3rem;
        font-weight: 700;
        margin-bottom: 15px;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    }
    
    .hero-subtitle {
        font-size: 1.4rem;
        opacity: 0.95;
        margin-bottom: 30px;
    }
    
    .stats-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }
    
    .stat-card {
        background: white;
        padding: 30px;
        border-radius: 15px;
        text-align: center;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    
    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.15);
    }
    
    .stat-number {
        font-size: 2.5rem;
        font-weight: 700;
        color: #667eea;
        margin-bottom: 10px;
    }
    
    .stat-label {
        font-size: 1rem;
        color: #6c757d;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    
    .feature-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 30px;
        margin-top: 40px;
    }
    
    .feature-card {
        background: white;
        padding: 35px 25px;
        border-radius: 15px;
        text-align: center;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        border: 2px solid transparent;
    }
    
    .feature-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 30px rgba(0,0,0,0.15);
        border-color: #667eea;
    }
    
    .feature-icon {
        font-size: 3rem;
        margin-bottom: 20px;
    }
    
    .feature-title {
        font-size: 1.4rem;
        font-weight: 600;
        margin-bottom: 15px;
        color: #2d3748;
    }
    
    .feature-description {
        color: #718096;
        font-size: 1rem;
        line-height: 1.6;
        margin-bottom: 20px;
    }
    
    .btn-feature {
        display: inline-block;
        padding: 12px 30px;
        border-radius: 25px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
    }
    
    .btn-primary-custom {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
    }
    
    .btn-primary-custom:hover {
        transform: scale(1.05);
        box-shadow: 0 5px 20px rgba(102, 126, 234, 0.4);
        color: white;
    }
    
    .btn-secondary-custom {
        background: white;
        color: #667eea;
        border: 2px solid #667eea;
    }
    
    .btn-secondary-custom:hover {
        background: #667eea;
        color: white;
    }
    
    .cta-section {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        padding: 50px;
        border-radius: 20px;
        text-align: center;
        margin-top: 50px;
        color: white;
    }
    
    .cta-title {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 15px;
    }
    
    .cta-text {
        font-size: 1.2rem;
        opacity: 0.95;
        margin-bottom: 25px;
    }
</style>

<!-- Hero Section -->
<div class="hero-section">
    <h1 class="hero-title">📚 Dobrodošli u Biblioteku</h1>
    <p class="hero-subtitle">Vaš digitalni pristup hiljadama knjiga - jednostavno, brzo i efikasno</p>
    @if (User.Identity?.IsAuthenticated != true)
    {
        <div class="mt-4">
            <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg me-3" style="border-radius: 25px; padding: 12px 40px; font-weight: 600;">
                Registruj se besplatno
            </a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-lg" style="border-radius: 25px; padding: 12px 40px; font-weight: 600;">
                Prijavi se
            </a>
        </div>
    }
</div>

<!-- Statistics Section -->
<div class="stats-container">
    <div class="stat-card">
        <div class="stat-number">500+</div>
        <div class="stat-label">Knjiga u fondu</div>
    </div>
    <div class="stat-card">
        <div class="stat-number">1,200+</div>
        <div class="stat-label">Primeraka</div>
    </div>
    <div class="stat-card">
        <div class="stat-number">150+</div>
        <div class="stat-label">Aktivnih članova</div>
    </div>
    <div class="stat-card">
        <div class="stat-number">24/7</div>
        <div class="stat-label">Online pristup</div>
    </div>
</div>

<!-- Feature Cards -->
<div class="feature-cards">
    <div class="feature-card">
        <div class="feature-icon">🔍</div>
        <h3 class="feature-title">Pretraga knjiga</h3>
        <p class="feature-description">
            Pretražujte našu bogatu kolekciju po naslovu, autoru ili žanru. Filtrirajte po dostupnosti i pronađite svoju sledeću omiljenu knjigu!
        </p>
        <a asp-controller="Books" asp-action="Index" class="btn btn-feature btn-primary-custom">
            Istraži katalog
        </a>
    </div>

    <div class="feature-card">
        <div class="feature-icon">📖</div>
        <h3 class="feature-title">Pozajmljivanje</h3>
        <p class="feature-description">
            Pozajmite knjige za 14 dana sa mogućnošću produženja. Pratite svoje pozajmice i rokove vraćanja u realnom vremenu.
        </p>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Books" asp-action="MyLoans" class="btn btn-feature btn-primary-custom">
                Moje pozajmice
            </a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login" class="btn btn-feature btn-secondary-custom">
                Prijavi se
            </a>
        }
    </div>

    <div class="feature-card">
        <div class="feature-icon">⏰</div>
        <h3 class="feature-title">Rezervacije</h3>
        <p class="feature-description">
            Rezervišite knjige koje su trenutno pozajmljene. Sistem će vas automatski obavestiti kada knjiga postane dostupna!
        </p>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Reservations" asp-action="Index" class="btn btn-feature btn-primary-custom">
                Moje rezervacije
            </a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login" class="btn btn-feature btn-secondary-custom">
                Prijavi se
            </a>
        }
    </div>
</div>

<!-- Call to Action -->
@if (User.Identity?.IsAuthenticated != true)
{
    <div class="cta-section">
        <h2 class="cta-title">Pridružite se našoj zajednici čitalaca!</h2>
        <p class="cta-text">Registracija je brza, jednostavna i potpuno besplatna.</p>
        <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg" style="border-radius: 25px; padding: 15px 50px; font-weight: 700;">
            Kreni odmah →
        </a>
    </div>
}
else
{
    <div class="cta-section">
        <h2 class="cta-title">Spremni za novu avanturu?</h2>
        <p class="cta-text">Pogledajte najnovije knjige koje smo dodali u našu kolekciju!</p>
        <a asp-controller="Books" asp-action="Index" class="btn btn-light btn-lg" style="border-radius: 25px; padding: 15px 50px; font-weight: 700;">
            Istraži knjige →
        </a>
    </div>
}