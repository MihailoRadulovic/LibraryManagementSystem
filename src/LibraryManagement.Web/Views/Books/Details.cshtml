@model LibraryManagement.Application.DTOs.BookDto
@{
    ViewData["Title"] = Model.Title;
}

<!-- SUCCESS/ERROR MESSAGES -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong>✅ Uspeh!</strong> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>❌ Greška!</strong> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="container mt-4">
    <div class="row">
        <!-- LEFT COLUMN - Book Details -->
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="card-title">@Model.Title</h2>
                    <h5 class="text-muted mb-4">@Model.Author</h5>
                    
                    <hr>
                    
                    <h5 class="mt-4">📋 Detalji knjige</h5>
                    <dl class="row">
                        <dt class="col-sm-4">ISBN:</dt>
                        <dd class="col-sm-8">@Model.ISBN</dd>
                        
                        <dt class="col-sm-4">Izdavač:</dt>
                        <dd class="col-sm-8">@(Model.Publisher ?? "Nepoznato")</dd>
                        
                        <dt class="col-sm-4">Godina izdanja:</dt>
                        <dd class="col-sm-8">@Model.PublicationYear</dd>
                        
                        <dt class="col-sm-4">Žanr:</dt>
                        <dd class="col-sm-8">@(Model.Genre ?? "Nepoznato")</dd>
                        
                        <dt class="col-sm-4">Ukupno primeraka:</dt>
                        <dd class="col-sm-8">@Model.TotalCopies</dd>
                        
                        <dt class="col-sm-4">Dostupno:</dt>
                        <dd class="col-sm-8">
                            <span class="badge @(Model.AvailableCopies > 0 ? "bg-success" : "bg-danger")">
                                @Model.AvailableCopies primeraka
                            </span>
                        </dd>
                    </dl>
                    
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <hr>
                        <h5 class="mt-4">📖 Opis</h5>
                        <p class="text-justify">@Model.Description</p>
                    }
                </div>
            </div>
        </div>
        
        <!-- RIGHT COLUMN - Actions -->
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">🎯 Akcije</h5>
                </div>
                <div class="card-body">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (Model.AvailableCopies > 0)
                        {
                            <!-- KNJIGA JE DOSTUPNA - Dugme za pozajmicu -->
                            <div class="alert alert-success mb-3">
                                <strong>✅ Dostupno!</strong><br>
                                <small>Knjiga je trenutno dostupna za pozajmicu.</small>
                            </div>
                            
                            <form asp-action="Borrow" method="post" class="mb-2"
                                  onsubmit="return confirm('Da li želite da pošaljete zahtev za pozajmicu ove knjige? Zahtev će biti poslat bibliotekaru na odobrenje.');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="bookId" value="@Model.Id" />
                                <button type="submit" class="btn btn-primary w-100 btn-lg">
                                    📤 Zatraži pozajmicu
                                </button>
                            </form>
                            
                            <small class="text-muted">
                                <i class="bi bi-info-circle"></i> 
                                Vaš zahtev će biti poslat bibliotekaru na odobrenje.
                            </small>
                        }
                        else
                        {
                            <!-- KNJIGA NIJE DOSTUPNA - Dugme za rezervaciju -->
                            <div class="alert alert-warning mb-3">
                                <strong>⚠️ Nedostupno!</strong><br>
                                <small>Svi primerci su trenutno pozajmljeni.</small>
                            </div>
                            
                            <form asp-action="Reserve" method="post" class="mb-3"
                                  onsubmit="return confirm('Da li želite da rezervišete ovu knjigu? Biće vam dodeljena pozicija u redu čekanja.');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="bookId" value="@Model.Id" />
                                <button type="submit" class="btn btn-warning w-100 btn-lg">
                                    📋 Rezerviši knjigu
                                </button>
                            </form>
                            
                            <small class="text-muted mb-3 d-block">
                                <i class="bi bi-info-circle"></i> 
                                Dobićete obaveštenje kada knjiga postane dostupna.
                            </small>
                            
                            @if (Model.ReservationCount > 0)
                            {
                                <div class="alert alert-info">
                                    <strong>💬 Red čekanja</strong><br>
                                    <small>Trenutno u redu: <strong>@Model.ReservationCount</strong> korisnika</small>
                                </div>
                                
                                <a asp-controller="Reservations" asp-action="Queue" asp-route-bookId="@Model.Id" 
                                   class="btn btn-sm btn-outline-secondary w-100">
                                    👥 Pogledaj red čekanja
                                </a>
                            }
                        }
                    }
                    else
                    {
                        <!-- NEPRIJAVLJENI KORISNIK -->
                        <div class="alert alert-warning">
                            <strong>⚠️ Prijava potrebna</strong><br>
                            <small>
                                <a asp-controller="Account" asp-action="Login" class="alert-link">Prijavite se</a> 
                                ili 
                                <a asp-controller="Account" asp-action="Register" class="alert-link">registrujte</a> 
                                da biste pozajmili ili rezervisali knjigu.
                            </small>
                        </div>
                    }
                </div>
            </div>
            
            <!-- INFO BOX -->
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="card shadow-sm mt-3">
                    <div class="card-body">
                        <h6 class="card-title">ℹ️ Informacije</h6>
                        <ul class="small mb-0">
                            <li>Rok za vraćanje: <strong>14 dana</strong></li>
                            <li>Kazna za kašnjenje: <strong>50 RSD/dan</strong></li>
                            <li>Rok za preuzimanje rezervacije: <strong>3 dana</strong></li>
                        </ul>
                    </div>
                </div>
            }
        </div>
    </div>
    
    <!-- BACK BUTTON -->
    <div class="row mt-4">
        <div class="col-12">
            <a asp-action="Index" class="btn btn-secondary">
                ⬅️ Nazad na listu knjiga
            </a>
        </div>
    </div>
</div>
