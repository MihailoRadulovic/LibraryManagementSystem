@using System.Security.Claims
<!DOCTYPE html>
<html lang="sr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistem za upravljanje bibliotekom</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom shadow-sm">
            <div class="container-fluid">
                <!-- Brand -->
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    📚 Biblioteka
                </a>
                
                <!-- Mobile toggle button -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <!-- Navbar content -->
                <div class="collapse navbar-collapse" id="navbarNav">
                    <!-- Left side menu -->
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Početna</a>
                        </li>
                        
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Books" asp-action="Index">Knjige</a>
                            </li>
                            
                            @if (User.IsInRole("Librarian") || User.IsInRole("Admin"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" id="librarianDropdown" 
                                       role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        📋 Bibliotekar
                                    </a>
                                    <ul class="dropdown-menu" aria-labelledby="librarianDropdown">
                                        <li>
                                            <a class="dropdown-item" asp-controller="Librarian" asp-action="PendingLoans">
                                                ⏳ Zahtevi za pozajmice
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Librarian" asp-action="PendingReturns">
                                                📦 Vraćanja na čekanju
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Books" asp-action="Create">
                                                ➕ Dodaj novu knjigu
                                            </a>
                                        </li>
                                    </ul>
                                </li>
                            }
                            
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Loans" asp-action="MyLoans">Moje pozajmice</a>
                            </li>
                            
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Reservations" asp-action="Index">Moje rezervacije</a>
                            </li>
                        }
                    </ul>
                    
                    <!-- Right side menu (Login/User dropdown) -->
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            var userEmail = User.FindFirstValue(ClaimTypes.Email);
                            var userRoles = new List<string>();
                            
                            if (User.IsInRole("Admin")) userRoles.Add("Admin");
                            if (User.IsInRole("Librarian")) userRoles.Add("Bibliotekar");
                            if (User.IsInRole("Reader")) userRoles.Add("Čitalac");
                            
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="userDropdown" 
                                   role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    👤 @userEmail
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <li>
                                        <span class="dropdown-item-text">
                                            <strong>Uloga:</strong> @string.Join(", ", userRoles)
                                        </span>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item">
                                                🚪 Odjavi se
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Prijavi se</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">Registruj se</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5 py-3">
        <div class="container text-center">
            &copy; 2024 - Sistem za upravljanje bibliotekom
        </div>
    </footer>
    
    <!-- Bootstrap JS Bundle (includes Popper) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>